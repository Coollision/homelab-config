apiVersion: v1
kind: Namespace
metadata:
  name: dr-test
---
# Explicitly create the Longhorn volume CR with a fixed name.
# This is what actually provisions storage on the nodes — the PV just references it.
# Survives deletion of the namespace/PVC/PV because it lives in the "storage" namespace.
apiVersion: longhorn.io/v1beta2
kind: Volume
metadata:
  name: dr-test-volume
  namespace: storage
  annotations:
    argocd.argoproj.io/sync-options: Delete=false,Prune=false
  labels:
    recurring-job-group.longhorn.io/default: enabled
    backup-type: daily
    recurring-job.longhorn.io/backup-daily: enabled
    protect: "true"

spec:
  accessMode: rwo
  dataEngine: v1
  dataLocality: disabled
  frontend: blockdev
  numberOfReplicas: 3
  size: "1073741824"   # 1Gi
  diskSelector: []
  nodeSelector: []
  replicaAutoBalance: ignored
  revisionCounterDisabled: true
  snapshotDataIntegrity: ignored
  Standby: false
  migratable: false
---
# Static PV referencing the Longhorn volume by its fixed name.
# ReclaimPolicy: Retain means the Longhorn volume survives deletion of the PV/PVC/namespace.
apiVersion: v1
kind: PersistentVolume
metadata:
  name: dr-test-volume
  annotations:
    longhorn.io/volume-name: dr-test-volume
spec:
  capacity:
    storage: 1Gi
  volumeMode: Filesystem
  accessModes:
    - ReadWriteOnce
  persistentVolumeReclaimPolicy: Retain
  storageClassName: longhorn-retain
  csi:
    driver: driver.longhorn.io
    fsType: ext4
    volumeHandle: dr-test-volume
---
apiVersion: v1
kind: PersistentVolumeClaim
metadata:
  name: dr-test-pvc
  namespace: dr-test
spec:
  storageClassName: longhorn-retain
  volumeName: dr-test-volume
  accessModes:
    - ReadWriteOnce
  resources:
    requests:
      storage: 1Gi
---
apiVersion: v1
kind: Pod
metadata:
  name: dr-test
  namespace: dr-test
spec:
  restartPolicy: Never
  containers:
    - name: dr-test
      image: busybox
      command:
        - sh
        - -c
        - |
          FILE=/data/timestamp.txt

          if [ -f "$FILE" ]; then
            echo "========================================="
            echo "RECOVERY RUN — file found on volume"
            echo "========================================="
            echo "Original write timestamp:"
            cat "$FILE"
            echo ""
            echo "✅ DR TEST PASSED — data survived deletion"
            echo ""
            echo "Appending recovery timestamp..."
            echo "Recovered at: $(date)" >> "$FILE"
            echo ""
            echo "Final file state:"
            cat "$FILE"
          else
            echo "========================================="
            echo "FRESH RUN — no file found, writing now"
            echo "========================================="
            echo "Written at: $(date)" > "$FILE"
            echo "✅ Timestamp written:"
            cat "$FILE"
            echo ""
            echo "Now delete everything and re-apply to test recovery:"
            echo "  kubectl delete -f dr-test.yaml"
            echo "  kubectl delete pv dr-test-volume"
            echo "  kubectl apply -f dr-test.yaml"
          fi

          sleep 3600
      volumeMounts:
        - name: data
          mountPath: /data
  volumes:
    - name: data
      persistentVolumeClaim:
        claimName: dr-test-pvc
