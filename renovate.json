{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":timezone(Europe/Brussels)"
  ],
  "schedule": [
    "after 7pm and before 10pm"
  ],
  "baseBranchPatterns": [
    "$default",
    "orphan/aws-tunnels-operator-standalone"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/\\.yaml$/"
    ],
    "ignorePaths": [
      "lib/**"
    ]
  },
  "packageRules": [
    {
      "description": "System & ArgoCD - automerge patch and minor",
      "matchBaseBranches": [
        "master"
      ],
      "matchFileNames": [
        "system/**",
        "argocd/**"
      ],
      "automerge": true,
      "automergeType": "branch",
      "ignoreTests": true,
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automergeSchedule": [
        "after 1am and before 4am"
      ]
    },
    {
      "description": "Workload - automerge patch only",
      "matchBaseBranches": [
        "master"
      ],
      "matchFileNames": [
        "workload/**"
      ],
      "automerge": true,
      "automergeType": "branch",
      "ignoreTests": true,
      "matchUpdateTypes": [
        "patch"
      ],
      "automergeSchedule": [
        "after 1am and before 4am"
      ]
    },
    {
      "description": "Operator branch - separate behavior",
      "matchBaseBranches": [
        "orphan/aws-tunnels-operator-standalone"
      ],
      "automerge": false
    }
  ]
}
