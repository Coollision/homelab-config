{
  "title": "Sablier — Scale to Zero",
  "uid": "sablier-scale-to-zero",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "tags": ["sablier", "scale-to-zero"],
  "timezone": "browser",
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "15s",
  "panels": [
    {
      "id": 1,
      "title": "Awake / Asleep history",
      "description": "One row per app. Green = awake (at least one active session), gray = asleep (scaled to zero). This is the \"time awake\" view — hover any segment to see when it started and how long it lasted.",
      "type": "state-timeline",
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sablier_group_locked",
          "legendFormat": "{{group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "asleep", "color": "dark-gray" } } },
            { "type": "value", "options": { "1": { "text": "awake", "color": "green" } } }
          ],
          "custom": { "lineWidth": 0, "fillOpacity": 100 }
        },
        "overrides": []
      },
      "options": {
        "showValue": "never",
        "mergeValues": true,
        "rowHeight": 0.8
      }
    },
    {
      "id": 2,
      "title": "Time remaining until sleep",
      "description": "sablier_session_expires_at_timestamp_seconds - time(), per active session. Counts down to zero, then the line disappears (session expired, instance stopped). Only appears for currently-awake apps.",
      "type": "timeseries",
      "gridPos": { "h": 9, "w": 16, "x": 0, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sablier_session_expires_at_timestamp_seconds - time()",
          "legendFormat": "{{group}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": false }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 3,
      "title": "Currently awake",
      "description": "Count of apps with an active session right now, out of all Sablier-managed apps.",
      "type": "stat",
      "gridPos": { "h": 9, "w": 8, "x": 16, "y": 9 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(sablier_group_locked)",
          "legendFormat": "awake",
          "refId": "A",
          "instant": true
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "count(sablier_group_locked)",
          "legendFormat": "total",
          "refId": "B",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "textMode": "value_and_name" } },
        "overrides": []
      },
      "options": {
        "graphMode": "none",
        "colorMode": "value",
        "textMode": "value_and_name",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      }
    },
    {
      "id": 4,
      "title": "Session requests / min",
      "description": "Requests hitting the Sablier middleware per app route, by strategy. Includes requests to already-awake apps (a pass-through check still counts).",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(sablier_session_requests_total[5m]) * 60) by (target, strategy)",
          "legendFormat": "{{target}} ({{strategy}})",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqpm",
          "custom": { "drawStyle": "line", "fillOpacity": 10 }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 5,
      "title": "Wake latency (p95)",
      "description": "How long provider.InstanceStart takes to bring a scaled-to-zero app back up, 95th percentile.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(sablier_instance_start_duration_seconds_bucket[15m])) by (le, instance))",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "fillOpacity": 10, "spanNulls": true }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["lastNotNull", "max"] },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 6,
      "title": "Instance stops by reason",
      "description": "Why each app was last scaled down — expired (normal idle timeout) vs anything else (worth investigating).",
      "type": "table",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 26 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sablier_instance_stops_total",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": false } } }
      ]
    }
  ]
}
